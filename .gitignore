node_modules/
dist/
__pycache__/
*.pyc

# Logs
*.log

# Misc
server-requirements.txt

# Claude Code — worktrees are temporary session directories, never commit them.
# launch.json is intentionally kept (project-level dev server config).
.claude/worktrees/